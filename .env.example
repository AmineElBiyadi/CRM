# =============================================================
# SmartEstateHub — .env.example
# Copiez ce fichier en .env et remplissez vos vraies valeurs.
# NE JAMAIS committer le fichier .env sur Git.
# =============================================================

# -------------------------------------------------------------
# Base de données PostgreSQL (Supabase IPv4 Session Pooler)
# -------------------------------------------------------------
DB_HOST=aws-X-REGION.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.[votre_id_projet]
DB_PASSWORD=votre_mot_de_passe_supabase

# HikariCP : configuration pour le mode Transaction de Supabase
spring.datasource.hikari.data-source-properties.prepareThreshold=0
spring.datasource.hikari.maximum-pool-size=3
spring.datasource.hikari.minimum-idle=1

# -------------------------------------------------------------
# IA Credentials (OpenAI ou NVIDIA NIM)
# -------------------------------------------------------------
# Pour NVIDIA NIM (Recommandé - gpt-oss-20b/120b)
NVIDIA_NIM_API_KEY=nvapi-CHANGE_ME
SPRING_AI_NVIDIA_CHAT_API_KEY=nvapi-CHANGE_ME
SPRING_AI_NVIDIA_EMBEDDING_API_KEY=nvapi-CHANGE_ME

# Pour OpenAI (gpt-4o)
OPENAI_API_KEY=sk-CHANGE_ME

# -------------------------------------------------------------
# RapidAPI — Listings immobiliers
# Obtenez votre clé sur : https://rapidapi.com
# -------------------------------------------------------------
RAPIDAPI_KEY=CHANGE_ME
RAPIDAPI_HOST=realty-in-us.p.rapidapi.com

# -------------------------------------------------------------
# SendGrid — E-mails transactionnels
# Obtenez votre clé sur : https://app.sendgrid.com/settings/api_keys
# -------------------------------------------------------------
SENDGRID_API_KEY=SG.CHANGE_ME
SENDGRID_FROM_EMAIL=noreply@smartestatehub.com

# -------------------------------------------------------------
# JWT — Sécurité (générer une clé aléatoire de 32+ caractères)
# Exemple : openssl rand -base64 64
# -------------------------------------------------------------
JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM_RANDOM_STRING

# -------------------------------------------------------------
# n8n — Automatisation des workflows
# URL du webhook n8n (local ou cloud)
# -------------------------------------------------------------
N8N_WEBHOOK_URL=http://localhost:5678/webhook
